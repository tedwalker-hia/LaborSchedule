# SQL Server connection string for Prisma
# Format: sqlserver://HOST:PORT;database=DB;user=USER;password=PW;encrypt=true;trustServerCertificate=true
DATABASE_URL="sqlserver://localhost:1433;database=labor_schedule;user=sa;password=changeme;encrypt=true;trustServerCertificate=true"

# Secret for signing JWT auth tokens — REQUIRED, app will not start without this.
# Generate with: openssl rand -base64 48
JWT_SECRET="replace-with-output-of-openssl-rand-base64-48"

# development | production | test
NODE_ENV="development"

# Set to "false" to skip writing audit rows to HIALaborScheduleAudit. Default true.
# Use when the audit table has not been created in the target database yet.
AUDIT_ENABLED="true"

# ─── Test fixtures ──────────────────────────────────────────────────────────
# Defaults are committed here so secret scanners don't flag literals in test
# files. Override per environment if a stronger value is required (e.g. CI
# running tests against a shared MSSQL).
TEST_USER_PASSWORD="Test@1234"
TEST_USER_PASSWORD_ALT="Test@5678"
TEST_DB_SA_PASSWORD="IntTest_Pa55w!"
